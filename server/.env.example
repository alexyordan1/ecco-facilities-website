# ============================================
# Ecco Facilities Chat Server — Environment
# ============================================
# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change port (default 3001)
PORT=3001

# Optional: allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://eccofacilities.com,https://www.eccofacilities.com
